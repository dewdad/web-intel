# SearXNG instance URL (required for search command)
SEARXNG_URL=http://localhost:8080
# SEARXNG_API_KEY=

# Crawl4AI Docker server (optional, for --docker mode)
CRAWL4AI_DOCKER_URL=http://localhost:11235
# CRAWL4AI_API_KEY=

# HTTP settings
HTTP_TIMEOUT=30
MAX_CONCURRENT_FETCHES=5

# Logging: DEBUG, INFO, WARNING, ERROR
# WRS_LOG_LEVEL=WARNING

# Custom User-Agent (optional)
# USER_AGENT=
