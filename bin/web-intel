#!/usr/bin/env bash
# web-intel wrapper — resolves its own location so it works from any CWD.
# Usage: /path/to/web-intel/bin/web-intel search "query"
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Find a working python3 (prefer 3.11-3.13 over 3.14+ for dep compat)
find_python() {
  for v in python3.13 python3.12 python3.11 python3; do
    if command -v "$v" &>/dev/null; then
      echo "$v"
      return
    fi
  done
  echo >&2 "ERROR: python3 not found. Install Python 3.11+"
  exit 1
}

PYTHON="$(find_python)"
exec "$PYTHON" "$SKILL_DIR/scripts/web.py" "$@"
